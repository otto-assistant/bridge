{
  "name": "discord-telegram-bridge",
  "version": "0.1.0",
  "description": "discord.js-to-Telegram adapter. Lets any discord.js bot control a Telegram bot without code changes.",
  "type": "module",
  "license": "MIT",
  "author": "remorses <beats.by.morse@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remorses/kimaki.git",
    "directory": "discord-telegram-bridge"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "AGENTS.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "echo-bot": "tsx scripts/echo-bot.ts"
  },
  "dependencies": {
    "discord-api-types": "^0.38.40",
    "spiceflow": "^1.18.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "@types/ws": "^8.5.0",
    "discord.js": "^14.25.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
